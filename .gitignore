# ── Secrets — NEVER commit these ──────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.Python
pip-wheel-metadata/

# ── Virtual environments ───────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/
.conda/

# ── Pipeline runtime data ─────────────────────────────────────────────────────
# User uploads and generated outputs — can be large, contain PII
uploads/
output/

# ChromaDB vector store — regenerated automatically on first run
chroma_db/

# ── ML model cache ─────────────────────────────────────────────────────────────
# sentence-transformers downloads ~80 MB on first use; don't commit it
.cache/
*.bin
*.safetensors

# ── Test / coverage artefacts ─────────────────────────────────────────────────
.pytest_cache/
.coverage
coverage.xml
htmlcov/

# ── Linter caches ─────────────────────────────────────────────────────────────
.ruff_cache/
.mypy_cache/

# ── Eval results ──────────────────────────────────────────────────────────────
# Generated JSON from eval runs — not source code
eval/eval_results*.json
eval/benchmark_results*.json

# ── IDE / editor ──────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Temporary files ───────────────────────────────────────────────────────────
tmp/
temp/
*.tmp
