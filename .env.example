# ── Required ──────────────────────────────────────────────────────────────────
# Free API key from https://build.nvidia.com  (click "Get API Key")
NVIDIA_API_KEY=nvapi-your-key-here

# ── Optional: LLM model ───────────────────────────────────────────────────────
# Any model slug from https://build.nvidia.com/explore/discover
# Free-tier options:
#   meta/llama-3.1-8b-instruct   (fast, good quality)
#   meta/llama-3.1-70b-instruct  (slower, higher quality, still free)
NVIDIA_MODEL=meta/llama-3.1-8b-instruct

# ── Optional: file paths ──────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
OUTPUT_DIR=./output
CHROMA_DIR=./chroma_db

# ── Optional: API server ──────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
